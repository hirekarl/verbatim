OPENROUTER_API_KEY=
# The OAuth client ID the Workspace Add-on's tokens are expected to carry as
# their audience/authorized-party. Required by the HTTP entrypoint
# (verbatim-server) to validate inbound bearer tokens; not used by the CLI.
GOOGLE_OAUTH_CLIENT_ID=
# A static secret shared between the backend and the Add-on's Script
# Properties, checked before any Google API call is made -- a cheap
# first-line filter against internet scanning/probing, independent of the
# (more expensive) tokeninfo check. Not used by the CLI.
BACKEND_SHARED_SECRET=
